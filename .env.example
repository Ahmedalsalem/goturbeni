NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by sitemap.ts/robots.ts to build absolute URLs. Falls back to
# http://localhost:3000 in local dev if unset.
NEXT_PUBLIC_SITE_URL=

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). gtag is omitted
# entirely when unset, so this is safe to leave blank in local dev.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Web Push (VAPID). Generate a keypair with `npx web-push generate-vapid-keys`
# — it's free, no third-party account needed. Public key is sent to the
# browser (NEXT_PUBLIC_), private key must stay server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:
